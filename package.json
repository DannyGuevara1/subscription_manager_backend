{
	"name": "subscription_manager_backend",
	"version": "1.0.0",
	"description": "",
	"imports": {
		"#/*": "./dist/*"
	},
	"type": "module",
	"main": "index.ts",
	"scripts": {
		"clean": "npx rimraf dist",
		"build": "npm run clean && tsc && tsc-alias",
		"start": "cross-env NODE_ENV=production node dist/src/server.js",
		"dev": "nodemon --exec tsx src/server.ts | pino-pretty",
		"lint:fix": "npx @biomejs/biome lint --write ./src",
		"format:fix": "npx @biomejs/biome format --write ./src",
		"test": "tsx --test tests/integration/auth/login.test.ts",
		"test:watch": "",
		"test:coverage": "",
		"db:test:push": "prisma db push --accept-data-loss",
		"db:migrate": "prisma migrate dev",
		"db:generate": "prisma generate",
		"db:deploy": "prisma migrate deploy",
		"db:validate": "prisma validate",
		"db:reset": "prisma migrate reset",
		"db:seed": "prisma db seed",
		"db:studio": "prisma studio"
	},
	"prisma": {
		"seed": "npx tsx prisma/seed.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DannyGuevara1/subscription_manager_backend.git"
	},
	"keywords": [],
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/DannyGuevara1/subscription_manager_backend/issues"
	},
	"homepage": "https://github.com/DannyGuevara1/subscription_manager_backend#readme",
	"dependencies": {
		"@prisma/client": "6.15.0",
		"@types/stack-trace": "0.0.33",
		"awilix": "12.0.5",
		"bcrypt": "6.0.0",
		"cookie-parser": "1.4.7",
		"cors": "2.8.5",
		"dotenv": "17.2.2",
		"express": "5.1.0",
		"helmet": "8.1.0",
		"jsonwebtoken": "9.0.2",
		"pino": "9.9.5",
		"redis": "5.10.0",
		"response-time": "2.3.4",
		"stack-trace": "1.0.0-pre2",
		"uuidv7": "1.0.2",
		"zod": "4.1.5"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.4",
		"@testcontainers/postgresql": "^11.11.0",
		"@testcontainers/redis": "^11.11.0",
		"@types/bcrypt": "6.0.0",
		"@types/cookie-parser": "1.4.9",
		"@types/cors": "2.8.19",
		"@types/express": "5.0.3",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "24.3.0",
		"@types/response-time": "2.3.9",
		"@types/supertest": "^6.0.3",
		"cross-env": "10.1.0",
		"dotenv-cli": "10.0.0",
		"nodemon": "3.1.10",
		"pino-pretty": "13.1.1",
		"prisma": "6.15.0",
		"supertest": "^7.2.2",
		"testcontainers": "^11.11.0",
		"tsc-alias": "1.8.16",
		"tsx": "4.20.5",
		"typescript": "5.9.2"
	}
}
